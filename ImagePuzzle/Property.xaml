<Window x:Class="ImagePuzzle.Property"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Settings_Title}"
        Height="420" Width="520" MinHeight="360" MinWidth="440"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">

            <!-- Resize -->
            <TabItem Header="{DynamicResource Settings_Tab_Resize}">
                <StackPanel Margin="12">
                    <TextBlock Text="{DynamicResource Settings_Resize_Mode}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <RadioButton x:Name="ResizeSizeMode" Content="{DynamicResource Settings_Resize_SizeMode}" Margin="0,0,0,4" IsChecked="True"/>
                    <StackPanel Orientation="Horizontal" Margin="16,0,0,8">
                        <TextBlock Text="{DynamicResource Settings_Resize_Width}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="ResizeWidthBox" Width="60" Text="800"/>
                        <TextBlock Text=" x " VerticalAlignment="Center"/>
                        <TextBox x:Name="ResizeHeightBox" Width="60" Text="800"/>
                        <TextBlock Text="px" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="ResizeKeepAspectBox" Content="{DynamicResource Settings_Resize_KeepAspect}" Margin="16,0,0,8" IsChecked="True"/>
                    <RadioButton x:Name="ResizePercentMode" Content="{DynamicResource Settings_Resize_PercentMode}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
                        <TextBox x:Name="ResizePercentBox" Width="60" Text="50"/>
                        <TextBlock Text="%" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Convert -->
            <TabItem Header="{DynamicResource Settings_Tab_Convert}">
                <StackPanel Margin="12">
                    <TextBlock Text="{DynamicResource Settings_Convert_Format}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ComboBox x:Name="ConvertFormatBox" Width="120" HorizontalAlignment="Left" Margin="0,0,0,12">
                        <ComboBoxItem Tag="jpg">JPG</ComboBoxItem>
                        <ComboBoxItem Tag="png">PNG</ComboBoxItem>
                        <ComboBoxItem Tag="webp">WebP</ComboBoxItem>
                        <ComboBoxItem Tag="bmp">BMP</ComboBoxItem>
                    </ComboBox>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource Settings_Convert_JpgQuality}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="JpgQualityBox" Width="50" Text="85"/>
                        <TextBlock Text=" (1-100)" VerticalAlignment="Center" Foreground="#757575" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource Settings_Convert_WebpQuality}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="WebpQualityBox" Width="50" Text="80"/>
                        <TextBlock Text=" (1-100)" VerticalAlignment="Center" Foreground="#757575" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Compress -->
            <TabItem Header="{DynamicResource Settings_Tab_Compress}">
                <StackPanel Margin="12">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="{DynamicResource Settings_Compress_JpgQuality}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="CompressJpgBox" Width="50" Text="75"/>
                        <TextBlock Text=" (1-100)" VerticalAlignment="Center" Foreground="#757575" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource Settings_Compress_PngLevel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="CompressPngBox" Width="50" Text="6"/>
                        <TextBlock Text=" (0-9)" VerticalAlignment="Center" Foreground="#757575" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Watermark -->
            <TabItem Header="{DynamicResource Settings_Tab_Watermark}">
                <StackPanel Margin="12">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource Settings_Watermark_Text}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="WatermarkTextBox" Width="200" Text="© 2026"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource Settings_Watermark_FontSize}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="WatermarkFontSizeBox" Width="50" Text="24"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource Settings_Watermark_Opacity}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="WatermarkOpacityBox" Width="50" Text="70"/>
                        <TextBlock Text=" (0-100)" VerticalAlignment="Center" Foreground="#757575" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource Settings_Watermark_Position}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="WatermarkPositionBox" Width="160">
                            <ComboBoxItem Tag="bottomright" IsSelected="True"><Run Text="{DynamicResource Pos_BottomRight}"/></ComboBoxItem>
                            <ComboBoxItem Tag="bottomleft"><Run Text="{DynamicResource Pos_BottomLeft}"/></ComboBoxItem>
                            <ComboBoxItem Tag="topright"><Run Text="{DynamicResource Pos_TopRight}"/></ComboBoxItem>
                            <ComboBoxItem Tag="topleft"><Run Text="{DynamicResource Pos_TopLeft}"/></ComboBoxItem>
                            <ComboBoxItem Tag="center"><Run Text="{DynamicResource Pos_Center}"/></ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Output -->
            <TabItem Header="{DynamicResource Settings_Tab_Output}">
                <StackPanel Margin="12">
                    <CheckBox x:Name="OpenFolderCheckBox" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource Settings_Output_OpenFolder}" TextWrapping="Wrap" MaxWidth="420"/>
                    </CheckBox>
                </StackPanel>
            </TabItem>

            <!-- Language -->
            <TabItem Header="{DynamicResource Settings_Language}">
                <StackPanel Margin="12">
                    <ComboBox x:Name="LanguageComboBox" Width="160" HorizontalAlignment="Left"
                              SelectionChanged="LanguageComboBox_SelectionChanged">
                        <ComboBoxItem Tag="ja">日本語</ComboBoxItem>
                        <ComboBoxItem Tag="en">English</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </TabItem>

        </TabControl>

        <Button Grid.Row="1" Content="{DynamicResource Btn_OK}"
                HorizontalAlignment="Right" Width="80" Margin="0,12,0,0"
                Click="OK_Button_Click"/>
    </Grid>
</Window>
